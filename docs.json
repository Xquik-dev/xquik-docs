{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Xquik",
  "description": "Xquik API docs for X data, real-time monitoring, webhooks, MCP, extractions, giveaway draws, OpenAPI, and SDKs.",
  "colors": {
    "primary": "#5c3327",
    "light": "#c49080",
    "dark": "#946150"
  },
  "fonts": {
    "family": "Outfit",
    "heading": {
      "family": "Instrument Serif"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://xquik.com"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "light",
    "strict": true
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#f5f3f0"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://xquik.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://xquik.com"
    }
  },
  "api": {
    "openapi": "openapi.yaml",
    "server": "https://xquik.com/api/v1",
    "auth": {
      "method": "key",
      "name": "x-api-key"
    },
    "playground": {
      "examples": {
        "languages": [
          "curl",
          "python",
          "javascript",
          "go"
        ]
      }
    }
  },
  "redirects": [
    {
      "source": "/sdk",
      "destination": "/sdks"
    },
    {
      "source": "/sdk/:slug*",
      "destination": "/sdks/:slug*"
    },
    {
      "source": "/sdks/javascript",
      "destination": "/sdks/typescript"
    },
    {
      "source": "/sdks/js",
      "destination": "/sdks/typescript"
    },
    {
      "source": "/sdks/node",
      "destination": "/sdks/typescript"
    },
    {
      "source": "/sdks/nodejs",
      "destination": "/sdks/typescript"
    },
    {
      "source": "/sdks/dotnet",
      "destination": "/sdks/csharp"
    },
    {
      "source": "/sdks/c-sharp",
      "destination": "/sdks/csharp"
    },
    {
      "source": "/sdks/terraform-provider",
      "destination": "/sdks/terraform"
    }
  ],
