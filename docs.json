{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Xquik",
  "description": "X (Twitter) real-time data platform. Extraction tools, giveaway draws, account monitoring & developer API.",
  "colors": {
    "primary": "#5c3327",
    "light": "#c49080",
    "dark": "#3b3836"
  },
  "fonts": {
    "family": "Outfit",
    "heading": {
      "family": "Instrument Serif"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://xquik.com"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "light",
    "strict": true
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#f5f3f0"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://xquik.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://xquik.com"
    }
  },
  "openapi": ["openapi.yaml"],
  "api": {
    "server": "https://xquik.com/api/v1",
    "auth": {
      "method": "key",
      "name": "x-api-key"
    },
    "playground": {
      "examples": {
        "languages": ["curl", "python", "javascript", "go"]
      }
    }
  },
